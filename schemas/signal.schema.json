{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Gengetau/agent-loop-control-template/schemas/signal.schema.json",
  "title": "Loop Signal",
  "description": "Validates machine-readable signals emitted between execution, review, and routing workflows.",
  "type": "object",
  "required": ["schema_version", "signal_type", "loop_id", "status", "created_at", "created_by"],
  "properties": {
    "schema_version": {
      "description": "Version of the signal schema.",
      "type": "integer",
      "minimum": 1
    },
    "signal_type": {
      "description": "Kind of workflow signal.",
      "type": "string",
      "enum": ["waiting-review", "reviewed"]
    },
    "loop_id": {
      "description": "Loop id associated with the signal.",
      "type": "string",
      "pattern": "^loop-[0-9]{3}-[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "status": {
      "description": "State represented by this signal.",
      "type": "string",
      "enum": ["waiting-review", "reviewed", "blocked", "failed"]
    },
    "report_path": {
      "description": "Path to the Codex report, required for waiting-review signals.",
      "type": "string"
    },
    "review_path": {
      "description": "Path to the review file, required for reviewed signals.",
      "type": "string"
    },
    "verdict": {
      "description": "Reviewer verdict for reviewed signals.",
      "type": "string",
      "enum": ["accepted", "changes-requested", "blocked", "rejected", "superseded"]
    },
    "created_at": {
      "description": "ISO 8601 timestamp when the signal was created.",
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "description": "Actor that created the signal.",
      "type": "string"
    },
    "parent_loop_id": {
      "description": "Parent loop id when this signal belongs to a follow-up loop, or null for standalone work.",
      "type": ["string", "null"],
      "pattern": "^loop-[0-9]{3}-[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "attempt": {
      "description": "Positive execution attempt number associated with this signal.",
      "type": "integer",
      "minimum": 1
    },
    "retry_count": {
      "description": "Number of completed retries associated with this signal.",
      "type": "integer",
      "minimum": 0
    },
    "max_retry_count": {
      "description": "Maximum number of execution retries allowed for the loop.",
      "type": "integer",
      "minimum": 0
    },
    "routing_hint": {
      "description": "Suggested next workflow route.",
      "type": "string"
    },
    "artifact_paths": {
      "description": "Related repository artifact paths.",
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "signal_type": {
            "const": "waiting-review"
          }
        },
        "required": ["signal_type"]
      },
      "then": {
        "required": ["report_path"]
      }
    },
    {
      "if": {
        "properties": {
          "signal_type": {
            "const": "reviewed"
          }
        },
        "required": ["signal_type"]
      },
      "then": {
        "required": ["review_path", "verdict"]
      }
    }
  ],
  "additionalProperties": true
}
