{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Gengetau/agent-loop-control-template/schemas/report.schema.json",
  "title": "Codex Report Metadata",
  "description": "Validates optional structured metadata for Codex execution reports.",
  "type": "object",
  "required": ["schema_version", "loop_id", "status", "executed_at", "report_path"],
  "properties": {
    "schema_version": {
      "description": "Version of the report metadata schema.",
      "type": "integer",
      "minimum": 1
    },
    "loop_id": {
      "description": "Loop id that this report describes.",
      "type": "string",
      "pattern": "^loop-[0-9]{3}-[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "status": {
      "description": "Execution status reported by Codex.",
      "type": "string",
      "enum": ["completed", "blocked", "failed", "partial"]
    },
    "business_repo": {
      "description": "Business repository in OWNER/REPO form, or null when not applicable.",
      "type": ["string", "null"]
    },
    "control_repo": {
      "description": "Control repository in OWNER/REPO form.",
      "type": "string"
    },
    "business_branch": {
      "description": "Business repository branch used by Codex.",
      "type": ["string", "null"]
    },
    "business_commit": {
      "description": "Business repository commit produced or inspected by Codex.",
      "type": ["string", "null"]
    },
    "pull_request": {
      "description": "Pull request URL if one was created.",
      "type": ["string", "null"],
      "format": "uri"
    },
    "executed_at": {
      "description": "ISO 8601 timestamp when execution completed.",
      "type": "string",
      "format": "date-time"
    },
    "report_path": {
      "description": "Path to the Markdown report.",
      "type": "string"
    },
    "files_changed": {
      "description": "Repository files changed during execution.",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation": {
      "description": "Validation commands and outcomes.",
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": true
}
